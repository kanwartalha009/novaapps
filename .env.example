# ── Database (Railway Postgres) ────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nova_apps?schema=public"

# ── API ────────────────────────────────────────────────────────
PORT=4000
# Dev only: accept ANY credentials, no database needed (ignored when NODE_ENV=production)
AUTH_DEV_BYPASS=false
JWT_SECRET="change-me-32-chars-minimum-secret"
APP_ENCRYPTION_KEY="32-byte-hex-key-for-shopify-credentials"
CORS_ORIGINS="http://nova-apps.localhost:3000,http://admin.nova-apps.localhost:3001,http://*.nova-apps.localhost:3002"
# Production only: scope auth cookies to the shared root domain so they flow across subdomains
# (api./admin./agency./…). Leave UNSET in local dev (host-only cookies on localhost).
# COOKIE_DOMAIN=.nova.app
# In-process maintenance jobs (reprocess-failed, reconcile, auto-approve) run on the API by default.
# Set to "false" on extra instances when scaling beyond one, to avoid redundant runs.
# JOBS_ENABLED=true

# ── Seed (dev only) ────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@nova-apps.dev"
SEED_ADMIN_PASSWORD="admin12345"

# ── Frontends ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000/v1"
NEXT_PUBLIC_APP_ADMIN_URL="http://localhost:3003"
# App backends: subdomain host ([app-slug].<host>) — engine amendment 2026-06-10-c
NEXT_PUBLIC_APP_HOST="nova-platform.localhost:3003"

# ── Per-app databases (one DB + migration history per app) ─────
# APP_DB_URL__SMART_BUNDLES="postgresql://postgres:postgres@localhost:5432/app_smart_bundles"
# APP_DB_URL__REVIEW_RADAR="postgresql://postgres:postgres@localhost:5432/app_review_radar"
# APP_DB_URL__STOCK_SENTRY="postgresql://postgres:postgres@localhost:5432/app_stock_sentry"

# ── Nova app integration (R1) — MUST match each app's .env (shared secrets) ──
NOVA_INSTALL_CONFIRM_SECRET="change-me-shared-with-each-app"
NOVA_INGRESS_HMAC_SECRET="change-me-shared-with-each-app"
# Dev store domain seeded for the Encore install-confirm test (packages/database/prisma/seed.ts)
DEV_SHOP_DOMAIN="encore-dev.myshopify.com"
# Attribution fallback: store owner for direct/no-ref installs (referral link is the primary path).
NOVA_DEFAULT_AGENCY_SLUG="nova"

# ── Shopify Partner API (authoritative app earnings — billing reconciliation) ──
# Enables POST /v1/admin/charges/reconcile + nightly true-up. Org id is in the Partner Dashboard URL;
# token needs "View financials" + "Manage apps". Flip setting billingSourceOfTruth="partner" to write.
# SHOPIFY_PARTNER_ORG_ID=
# SHOPIFY_PARTNER_API_TOKEN=
# SHOPIFY_PARTNER_API_VERSION="2025-01"
# NOVA_SHOPIFY_APP_GID="gid://shopify/App/…"   # scopes reconciliation to Encore

# ── Payout providers (Phase 4/5) ───────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=

# ── Tools: entitlements + tool-engine (P3/P4) ──────────────────
NOVA_ENTITLEMENT_SECRET="change-me-shared-with-each-tool"
NOVA_TOOL_CI_SECRET="change-me-shared-with-tool-ci"

# ── Store Bridge (P5, ADR-009) — Nova-owned OAuth app + proxy ──
NOVA_API_PUBLIC="http://localhost:4000/v1"          # public base for the OAuth redirect_uri
SHOPIFY_BRIDGE_CLIENT_ID="from-the-nova-store-bridge-app"
SHOPIFY_BRIDGE_SECRET="from-the-nova-store-bridge-app"
NOVA_BRIDGE_SCOPES="read_products,write_products"     # least-privilege superset the bridge requests
NOVA_BRIDGE_SECRET="change-me-shared-with-each-tool"  # signs the GraphQL proxy + relay
SHOPIFY_API_VERSION="2025-01"
# NOVA_BRIDGE_RATE_PER_MIN=120                         # per-store proxy budget (in-process)
