{
  "name": "@nova/database",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "generate": "prisma generate",
    "build": "prisma generate && tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'lint: database (todo)'",
    "migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "migrate:deploy:ci": "prisma migrate deploy",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "seed:ci": "tsx prisma/seed.ts",
    "reconcile": "dotenv -e ../../.env -- tsx scripts/reconcile-money.ts",
    "studio": "dotenv -e ../../.env -- prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.8.0"
  },
  "devDependencies": {
    "@nova/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "argon2": "^0.41.1",
    "dotenv-cli": "^7.4.0",
    "prisma": "^6.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
