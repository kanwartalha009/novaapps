{
  "name": "nova-apps-platform",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "pnpm --filter @nova/database generate",
    "db:migrate": "pnpm --filter @nova/database migrate:dev",
    "db:deploy": "pnpm --filter @nova/database migrate:deploy",
    "db:seed": "pnpm --filter @nova/database seed"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.7.0"
  }
}
